{
  "name": "shrine-mobile-web",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "start": "node server.js",
    "mobile:sync": "npm run build && npx cap sync android",
    "android:bundle": "node scripts/check-release-env.mjs android && npm run mobile:sync && cd android && gradlew.bat bundleRelease",
    "android:bundle:unsigned": "npm run mobile:sync && cd android && gradlew.bat bundleRelease",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@cloudflare/vite-plugin": "^1.42.3",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0",
    "ws": "^8.21.0"
  }
}
