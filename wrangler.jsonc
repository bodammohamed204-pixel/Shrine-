{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "shrine-the-book-of-heaven",
  "account_id": "aacd59c18e272207cbf72448d5a38683",
  "main": "worker/index.js",
  "compatibility_date": "2026-06-01",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "app.shrine-app.com/*",
      "zone_name": "shrine-app.com"
    }
  ],
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/shrines/*", "/share/*"]
  },
  "send_email": [
    { "name": "EMAIL" }
  ],
  "vars": {
    "ALLOWED_ORIGINS": "https://app.shrine-app.com,https://book-of-heaven.onholding.workers.dev,https://book-of-heaven.bodammohamed204.workers.dev,https://shrine-the-book-of-heaven.bodammohamed204.workers.dev,http://localhost,capacitor://localhost",
    "OTP_EMAIL_FROM": "noreply@shrine-app.com",
    "OTP_EMAIL_FROM_NAME": "Shrine"
  },
  "observability": {
    "enabled": true
  }
}
