VITE_API_BASE_URL=https://book-of-heaven.onholding.workers.dev
VITE_APP_URL=https://app.shrine-app.com

# Backend hosting
ONCALLOS_API_KEY=oc_live_your_key_here
OTP_EMAIL_SECRET=replace-with-a-long-random-secret
OTP_EMAIL_FROM=noreply@yourdomain.com
OTP_EMAIL_FROM_NAME=Shrine
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_EMAIL_API_TOKEN=your-email-sending-api-token
ALLOWED_ORIGINS=https://your-production-app.example.com,capacitor://localhost
PORT=5184
NODE_ENV=production

# Android release signing
ANDROID_KEYSTORE_PATH=C:\absolute\path\to\shrine-upload-key.jks
ANDROID_KEYSTORE_PASSWORD=change-me
ANDROID_KEY_ALIAS=shrine-upload
ANDROID_KEY_PASSWORD=change-me
